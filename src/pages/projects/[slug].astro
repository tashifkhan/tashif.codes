---
import Layout from "../../layouts/Layout.astro";
import {
	Github,
	ExternalLink,
	ArrowLeft,
	FileText,
	GitFork,
	BarChart3,
} from "lucide-react";
import { allProjects, type Project } from "../../data/projects";
import MarkdownRenderer from "../../components/MarkdownRenderer.astro";
import { fetchAnalyticsProjects, hasAnalytics, getAnalyticsSlug } from "../../data/analyticsProjects";

import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { AnimatedTooltip } from "@/components/ui/animated-tooltip";

const { project, projectHasAnalytics, analyticsSlug } = Astro.props as { project: Project; projectHasAnalytics: boolean; analyticsSlug: string };

let decodedReadme = "";
if (project.readme) {
	decodedReadme = Buffer.from(project.readme, "base64").toString("utf-8");
}

export async function getStaticPaths() {
	const analyticsProjects = await fetchAnalyticsProjects();
	return allProjects.map((project: Project) => ({
		params: { slug: project.slug },
		props: { 
			project,
			projectHasAnalytics: hasAnalytics(project.slug, analyticsProjects),
			analyticsSlug: getAnalyticsSlug(project.slug)
		},
	}));
}
---

<Layout title={project.title}>
	<div
		class="relative min-h-screen bg-gradient-to-b from-gray-50 to-white dark:from-gray-950 dark:to-gray-900 text-gray-900 dark:text-gray-100 transition-colors duration-300 font-sans"
	>
		<div
			class="pointer-events-none absolute inset-0 [mask-image:radial-gradient(80%_60%_at_50%_0%,black,transparent)]"
		>
			<div
				class="h-40 bg-gradient-to-b from-orange-200/40 to-transparent dark:from-orange-900/20"
			>
			</div>
		</div>
		<header
			class="relative bg-white/80 dark:bg-gray-900/80 backdrop-blur border-b border-gray-200/60 dark:border-gray-800/60 transition-colors duration-300"
		>
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
			<a
				href="/projects"
				data-haptic-back
				class="flex items-center text-primary dark:text-primary hover:text-primary/80 hover:underline mb-4 sm:mb-6 text-sm sm:text-base font-medium"
			>
					<ArrowLeft className="w-4 h-4 mr-2" /> Back to Projects
				</a>
				<h1
					class="text-3xl sm:text-4xl lg:text-5xl font-bold bg-gradient-to-r from-primary to-primary/80 dark:from-white dark:to-gray-300 bg-clip-text text-transparent mb-4"
				>
					{project.title}
				</h1>
				<p
					class="text-gray-600 dark:text-gray-300 mb-6 text-base sm:text-lg leading-relaxed max-w-3xl"
				>
					{project.description}
				</p>
				{
					project.parentRepo && (
					<a
						href={`https://github.com/${project.parentRepo}`}
						target="_blank"
						rel="noopener noreferrer"
						data-haptic-external
					>
							<div class="flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 mb-6 -mt-4 bg-gray-100/50 dark:bg-gray-800/50 w-fit px-3 py-1 rounded-full border border-gray-200 dark:border-gray-700">
								<GitFork className="w-4 h-4" />
								<span>
									Forked from{" "}
									<strong class="font-medium text-gray-700 dark:text-gray-300">
										{project.parentRepo}
									</strong>
								</span>
							</div>
						</a>
					)
				}
				<div class="flex flex-wrap gap-2 mb-6">
					{
						project.languages.map((lang: string) => (
							<Badge
								variant="secondary"
								className="text-[10px] font-medium bg-secondary/50 hover:bg-secondary/70 transition-colors"
							>
								{lang}
							</Badge>
						))
					}
				</div>

				{
					project.contributors && project.contributors.length > 1 && (
						<div class="flex items-center gap-4 mb-6">
							<span class="text-sm font-medium text-gray-500 dark:text-gray-400">
								Contributors
							</span>
							<div class="flex flex-row items-center justify-start">
								<AnimatedTooltip
									client:load
									items={project.contributors.map((c) => ({
										id: c.login === "tashifkhan" ? 1 : Math.random(), // Ensure stable ID for main user if needed, or just unique
										name: c.login,
										designation: `${c.contributions} contributions`,
										image: c.avatar_url,
										url: c.html_url,
									}))}
								/>
							</div>
						</div>
					)
				}

				<div class="flex flex-row flex-wrap items-center gap-3 sm:gap-6">
					{
						project.live_website_url && (
							<Button
								variant="default"
								size="sm"
								className="h-8 text-xs gap-1.5 shadow-sm"
								data-live-link
								data-url={project.live_website_url}
							>
							<a
								class="flex items-center gap-1"
								href={project.live_website_url}
								target="_blank"
								rel="noopener noreferrer"
								data-haptic-external
							>
									<ExternalLink className="w-3.5 h-3.5" />
									Live Demo
								</a>
							</Button>
						)
					}
					<Button
						variant="outline"
						size="sm"
						className="h-8 text-xs gap-1.5 bg-background/50 backdrop-blur-sm"
						data-github-link
						data-url={project.github_link}
					>
						<a
							class="flex items-center gap-1"
							href={project.github_link}
							target="_blank"
							rel="noopener noreferrer"
							data-haptic-external
						>
							<Github className="w-3.5 h-3.5" />
							Source
						</a>
					</Button>
					{
						project.docs_slug && (
							<Button
								variant="outline"
								size="sm"
								className="h-8 text-xs gap-1.5 shadow-sm hover:bg-secondary/70 transition-colors"
								asChild
							>
							<a
								href={`/docs/${project.docs_slug}`}
								class="flex items-center gap-1"
								data-haptic-nav
							>
									<FileText className="w-3.5 h-3.5" />
									Docs
								</a>
							</Button>
						)
					}
					{
						projectHasAnalytics && (
							<Button
								variant="outline"
								size="sm"
								className="h-8 text-xs gap-1.5 shadow-sm hover:bg-blue-500/10 hover:border-blue-500/30 transition-colors"
								asChild
							>
							<a
								href={`/projects/stats?project=${analyticsSlug}`}
								class="flex items-center gap-1"
								data-haptic-nav
							>
									<BarChart3 className="w-3.5 h-3.5" />
									Stats
								</a>
							</Button>
						)
					}
				</div>
			</div>
		</header>

		<main class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
			<div
				class="bg-white/80 dark:bg-gray-900/80 backdrop-blur-xl p-6 sm:p-8 lg:p-10 rounded-2xl border border-gray-200/50 dark:border-gray-700/50 shadow-lg"
			>
				{
					project.readme ? (
						<MarkdownRenderer
							content={decodedReadme}
							githubBaseUrl={project.github_link}
						/>
					) : (
						<div class="text-center py-12">
							<p class="text-gray-600 dark:text-gray-400 text-lg">
								No documentation available for this project.
							</p>
							<p class="text-gray-500 dark:text-gray-500 text-sm mt-2">
								Check the GitHub repository for more details.
							</p>
						</div>
					)
				}
			</div>
		</main>
	</div>
</Layout>

<script>
	import { WebHaptics } from "web-haptics";
	const haptics = new WebHaptics();

	document.addEventListener("DOMContentLoaded", () => {
		document.querySelectorAll("[data-haptic-back]").forEach((el) =>
			el.addEventListener("click", () => haptics.trigger("light"))
		);
		document.querySelectorAll("[data-haptic-nav]").forEach((el) =>
			el.addEventListener("click", () => haptics.trigger("light"))
		);
		document.querySelectorAll("[data-haptic-external]").forEach((el) =>
			el.addEventListener("click", () => haptics.trigger("light"))
		);
	});
</script>
